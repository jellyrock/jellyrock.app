---
import { Image } from 'astro:assets';
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';

const screenshotGlobs = import.meta.glob<{ default: ImageMetadata }>('../assets/images/jellyrock/screenshots/*.png', {
  eager: true,
});
const screenshots = Object.entries(screenshotGlobs).map(([filepath, mod]) => ({
  name: filepath.split('/').pop()?.replace('.png', '') ?? '',
  src: mod.default,
}));

const metadata = {
  title: 'Screenshots',
};
---

<Layout metadata={metadata}>
  <HeroText>
    <Fragment slot="title">
      <span class="text-accent">Screenshots</span>
    </Fragment>

    <Fragment slot="subtitle">
      See what JellyRock looks like on your Roku. Click any image to view full size.
    </Fragment>
  </HeroText>

  <section class="px-4 pb-16">
    <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-6">
      {
        screenshots.map((screenshot) => (
          <Image
            src={screenshot.src}
            alt={`JellyRock ${screenshot.name} screen`}
            class="rounded-lg shadow-lg w-full cursor-zoom-in"
            data-zoomable
            loading="lazy"
            widths={[480, 800, 1200, 1920]}
            sizes="(max-width: 768px) 100vw, 50vw"
          />
        ))
      }
    </div>
  </section>
</Layout>

<script>
  import mediumZoom from 'medium-zoom';
  mediumZoom('[data-zoomable]', {
    background: 'rgba(0, 0, 0, 0.9)',
  });
</script>
