---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Features2 from '~/components/widgets/Features2.astro';

const metadata = {
  title: 'Contact',
};
---

<Layout metadata={metadata}>
  <HeroText>
    <Fragment slot="title">
      Get in <span class="text-accent">touch</span>
    </Fragment>

    <Fragment slot="subtitle">
      Questions, bug reports, or just want to say hi? Here's how to reach us.
    </Fragment>
  </HeroText>

  <Features2
    columns={2}
    items={[
      {
        title: 'Matrix Chat',
        description:
          'Join the community chat for real-time discussion, troubleshooting, and casual conversation.<br><a href="https://matrix.to/#/#jellyrock-app:matrix.org" target="_blank" class="text-accent underline">#jellyrock-app:matrix.org</a>',
        icon: 'tabler:message-circle',
      },
      {
        title: 'GitHub Issues',
        description:
          'Report bugs or request features. Please search existing issues first to avoid duplicates.<br><a href="https://github.com/jellyrock/jellyrock/issues" target="_blank" class="text-accent underline">github.com/jellyrock/jellyrock/issues</a>',
        icon: 'tabler:bug',
      },
      {
        title: 'GitHub Discussions',
        description:
          'Ask questions, share setups, or discuss ideas with the community.<br><a href="https://github.com/jellyrock/jellyrock/discussions" target="_blank" class="text-accent underline">github.com/jellyrock/jellyrock/discussions</a>',
        icon: 'tabler:messages',
      },
      {
        title: 'Email Support',
        description:
          'For general questions or support requests.<br><a href="mailto:support@jellyrock.app" class="text-accent underline">support@jellyrock.app</a>',
        icon: 'tabler:mail',
      },
    ]}
  />
</Layout>
