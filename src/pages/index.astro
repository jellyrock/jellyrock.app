---
import { Image } from 'astro:assets';
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

import { features, HOMEPAGE_FEATURE_COUNT } from '~/data/features';

const metadata = {
  title: 'JellyRock — A Jellyfin client for Roku',
  ignoreTitleTemplate: true,
};

// Dynamically import all screenshots from the fetched assets
const screenshotGlobs = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/images/jellyrock/screenshots/*.png',
  { eager: true }
);
const allScreenshots = Object.entries(screenshotGlobs).map(([filepath, mod]) => ({
  name: filepath.split('/').pop()?.replace('.png', '') ?? '',
  src: mod.default,
}));

// Pick a hero screenshot (prefer 'home', fallback to first)
const heroScreenshot = allScreenshots.find((s) => s.name === 'home') || allScreenshots[0];
// Show up to 6 screenshots in the gallery (excluding hero)
const HOMEPAGE_SCREENSHOT_COUNT = 4;
const galleryScreenshots = allScreenshots
  .filter((s) => s !== heroScreenshot)
  .slice(0, HOMEPAGE_SCREENSHOT_COUNT);
const hasMoreScreenshots = allScreenshots.length > HOMEPAGE_SCREENSHOT_COUNT + 1;

// Show first N features on homepage
const homepageFeatures = features.slice(0, HOMEPAGE_FEATURE_COUNT);
const hasMoreFeatures = features.length > HOMEPAGE_FEATURE_COUNT;
---

<Layout metadata={metadata}>
  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Install',
        href: '/install',
        icon: 'tabler:download',
      },
      {
        text: 'View Source',
        href: 'https://github.com/jellyrock/jellyrock',
        target: '_blank',
        icon: 'tabler:brand-github',
      },
    ]}
    image={heroScreenshot ? { src: heroScreenshot.src, alt: 'JellyRock home screen on Roku' } : undefined}
  >
    <Fragment slot="title">
      Your media, your way, on <span class="text-accent">Roku</span>
    </Fragment>

    <Fragment slot="subtitle">
      <span class="font-semibold">JellyRock</span> is a free, open source Jellyfin client for Roku devices.
      Stream your movies, shows, music, and more — no subscriptions, no tracking, no compromise.
    </Fragment>
  </Hero>

  <Features
    id="features"
    tagline="Features"
    title="Why JellyRock?"
    subtitle="Built by the community, for the community. JellyRock focuses on stability, performance, and a great user experience."
    items={homepageFeatures}
  />

  {hasMoreFeatures && (
    <div class="text-center -mt-8 mb-12">
      <a href="/features" class="btn">
        View all features
      </a>
    </div>
  )}

  <!-- Screenshot Gallery -->
  {galleryScreenshots.length > 0 && (
    <section class="py-16 px-4" style="background-color: var(--jr-bg-secondary)">
      <div class="max-w-6xl mx-auto">
        <h2 class="text-3xl font-bold text-center mb-2 font-heading" style="color: var(--jr-text-primary)">
          See JellyRock in action
        </h2>
        <p class="text-center mb-10" style="color: var(--jr-text-secondary)">
          Designed for the big screen — optimized for Roku's 10-foot interface
        </p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {galleryScreenshots.map((screenshot) => (
            <Image
              src={screenshot.src}
              alt={`JellyRock ${screenshot.name} screen`}
              class="rounded-lg shadow-lg w-full cursor-zoom-in"
              data-zoomable
              loading="lazy"
              widths={[480, 800, 1200]}
              sizes="(max-width: 768px) 100vw, 50vw"
            />
          ))}
        </div>
        {hasMoreScreenshots && (
          <div class="text-center mt-8">
            <a href="/screenshots" class="btn">
              View all screenshots
            </a>
          </div>
        )}
      </div>
    </section>
  )}

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Install',
        href: '/install',
        icon: 'tabler:download',
      },
      {
        text: 'Support Development',
        href: '/donate',
        icon: 'tabler:heart',
      },
    ]}
  >
    <Fragment slot="title">
      Ready to try <span class="text-accent">JellyRock</span>?
    </Fragment>

    <Fragment slot="subtitle">
      Free and open source. Install JellyRock on your Roku from the Channel Store — no account required.
    </Fragment>
  </CallToAction>
</Layout>

<script>
  import mediumZoom from 'medium-zoom';
  mediumZoom('[data-zoomable]', {
    background: 'rgba(0, 0, 0, 0.9)',
  });
</script>
