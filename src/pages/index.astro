---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'JellyRock — A Jellyfin client for Roku',
  ignoreTitleTemplate: true,
};

// Dynamically import all screenshots from the fetched assets
const screenshotGlobs = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/images/jellyrock/screenshots/*.png',
  { eager: true }
);
const screenshots = Object.entries(screenshotGlobs).map(([filepath, mod]) => ({
  name: filepath.split('/').pop()?.replace('.png', '') ?? '',
  src: mod.default,
}));

// Pick a hero screenshot (prefer 'home', fallback to first)
const heroScreenshot = screenshots.find((s) => s.name === 'home') || screenshots[0];
// Remaining screenshots for the gallery
const galleryScreenshots = screenshots.filter((s) => s !== heroScreenshot);
---

<Layout metadata={metadata}>
  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Try the Demo',
        href: 'https://demo.jellyrock.app',
        target: '_blank',
        icon: 'tabler:player-play',
      },
      {
        text: 'View Source',
        href: 'https://github.com/jellyrock/jellyrock',
        target: '_blank',
        icon: 'tabler:brand-github',
      },
    ]}
    image={heroScreenshot ? { src: heroScreenshot.src, alt: 'JellyRock home screen on Roku' } : undefined}
  >
    <Fragment slot="title">
      Your media, your way, on <span class="text-accent">Roku</span>
    </Fragment>

    <Fragment slot="subtitle">
      <span class="font-semibold">JellyRock</span> is a free, open source Jellyfin client for Roku devices.
      Stream your movies, shows, music, and more — no subscriptions, no tracking, no compromise.
    </Fragment>
  </Hero>

  <Features
    id="features"
    tagline="Features"
    title="Why JellyRock?"
    subtitle="Built by the community, for the community. JellyRock focuses on stability, performance, and a great user experience."
    items={[
      {
        title: 'Direct Play Priority',
        description:
          'Plays your media directly whenever possible, avoiding unnecessary transcoding for the best quality and lowest server load.',
        icon: 'tabler:player-play',
      },
      {
        title: 'Subtitle Support',
        description:
          'Full support for external and embedded subtitles including SRT, VTT, and ASS formats with custom rendering.',
        icon: 'tabler:text-caption',
      },
      {
        title: 'Trickplay Thumbnails',
        description:
          'Preview thumbnails while scrubbing through video, making it easy to find the exact moment you want.',
        icon: 'tabler:photo-scan',
      },
      {
        title: 'Cinema Mode',
        description:
          'Play custom intros before your movies and shows for an authentic theater experience at home.',
        icon: 'tabler:movie',
      },
      {
        title: 'Themeable Interface',
        description:
          'Choose from multiple built-in color themes or create your own custom theme to match your style.',
        icon: 'tabler:palette',
      },
      {
        title: 'Free & Open Source',
        description:
          'No ads, no tracking, no subscriptions. Community-driven development with full transparency.',
        icon: 'tabler:heart-handshake',
      },
    ]}
  />

  <!-- Screenshot Gallery -->
  {galleryScreenshots.length > 0 && (
    <section class="py-16 px-4" style="background-color: var(--jr-bg-secondary)">
      <div class="max-w-6xl mx-auto">
        <h2 class="text-3xl font-bold text-center mb-2 font-heading" style="color: var(--jr-text-primary)">
          See JellyRock in action
        </h2>
        <p class="text-center mb-10" style="color: var(--jr-text-secondary)">
          Designed for the big screen — optimized for Roku's 10-foot interface
        </p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {galleryScreenshots.map((screenshot) => (
            <img
              src={screenshot.src.src}
              alt={`JellyRock ${screenshot.name} screen`}
              class="rounded-lg shadow-lg w-full"
              width={screenshot.src.width}
              height={screenshot.src.height}
              loading="lazy"
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Try the Demo',
        href: 'https://demo.jellyrock.app',
        target: '_blank',
        icon: 'tabler:player-play',
      },
      {
        text: 'Support Development',
        href: 'https://github.com/sponsors/cewert',
        target: '_blank',
        icon: 'tabler:heart',
      },
    ]}
  >
    <Fragment slot="title">
      Ready to try <span class="text-primary">JellyRock</span>?
    </Fragment>

    <Fragment slot="subtitle">
      Free and open source. Try the browser demo instantly, or install it on your Roku from the Channel Store.
    </Fragment>
  </CallToAction>
</Layout>
