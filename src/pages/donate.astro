---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Button from '~/components/ui/Button.astro';

const metadata = {
  title: 'Donate',
};

// Contributors you can sponsor directly.
// Add more entries here as the project grows.
const contributors = [
  {
    name: 'Charles Ewert',
    role: 'Maintainer',
    handle: 'cewert',
    url: 'https://github.com/sponsors/cewert',
  },
];
---

<Layout metadata={metadata}>
  <HeroText>
    <Fragment slot="title">
      Support <span class="text-accent">JellyRock</span>
    </Fragment>

    <Fragment slot="subtitle">
      JellyRock is free and open source. If it's improved your Jellyfin experience on Roku, consider supporting ongoing
      development with a one-time or recurring donation.
    </Fragment>
  </HeroText>

  <section class="px-4 pb-20">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-2xl font-bold mb-6 font-heading" style="color: var(--jr-text-primary)">Sponsor a Contributor</h2>
      <div class="space-y-4">
        {
          contributors.map((contributor) => (
            <div
              class="flex items-center justify-between p-5 rounded-lg border"
              style="background-color: var(--jr-bg-secondary); border-color: var(--jr-text-disabled)"
            >
              <div>
                <div class="font-semibold" style="color: var(--jr-text-primary)">
                  {contributor.name}
                </div>
                <div class="text-sm" style="color: var(--jr-text-secondary)">
                  {contributor.role} ·
                  <a href={`https://github.com/${contributor.handle}`} target="_blank" rel="noopener" class="underline">
                    @{contributor.handle}
                  </a>
                </div>
              </div>
              <Button href={contributor.url} target="_blank" variant="primary" icon="tabler:heart">
                Sponsor
              </Button>
            </div>
          ))
        }
      </div>

      <div class="mt-12 text-center text-sm" style="color: var(--jr-text-secondary)">
        <p>
          100% of donations go directly to the individual contributor via GitHub Sponsors. JellyRock does not collect or
          hold any funds.
        </p>
      </div>
    </div>
  </section>
</Layout>
